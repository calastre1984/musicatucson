---
import { Icon } from "astro-icon/components";

const titulo = Astro.props.titulo
const artista = Astro.props.artista
const album = Astro.props.album
const img = Astro.props.img
const duracion = Astro.props.duracion

interface Props {
    titulo: string
    artista: string
    album: string
    img: string
    duracion: string
}
---

<section>
<div>
    <img src={img} alt="">
</div>
<div>
    <h3>Titulo</h3>
    <p>artista</p>
    <p>album</p>

</div>
</section>